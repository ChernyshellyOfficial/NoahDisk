<Window x:Class="SpaceSaver.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SpaceSaver.Gui"
        Title="SpaceSaver" Height="780" Width="1200" MinHeight="520" MinWidth="900"
        Icon="app.ico"
        Background="{DynamicResource WinBg}" FontFamily="Segoe UI" UseLayoutRounding="True"
        AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop" KeyDown="OnWindowKey">

    <Window.Resources>
        <!-- обычная кнопка -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BtnPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource FgDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- акцентная кнопка -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AccentFg}"/>
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource FgDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- хлебная крошка как ссылка -->
        <Style x:Key="CrumbButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource CrumbFg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource CrumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- поле пути -->
        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Fg}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- строка списка -->
        <Style x:Key="RowItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource RowHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource RowSel}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- панель инструментов -->
        <Border Grid.Row="0" Background="{DynamicResource BarBg}" Padding="10,8">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Left" x:Name="UpButton" Content="↑" Width="36"
                        Style="{StaticResource ToolButton}" Click="OnUp" ToolTip="Вверх (Backspace)"/>
                <Button DockPanel.Dock="Left" x:Name="BrowseButton" Content="Обзор…" Margin="6,0,0,0"
                        Style="{StaticResource ToolButton}" Click="OnBrowse"/>
                <Button DockPanel.Dock="Left" x:Name="GlobalButton" Content="Глобальный скан" Margin="10,0,0,0"
                        Style="{StaticResource AccentButton}" Click="OnGlobalScan"
                        ToolTip="Полный скан папки и раскладка всего значимого (игры, программы, тяжёлые файлы) в один вид"/>
                <Button DockPanel.Dock="Right" x:Name="RefreshButton" Content="Обновить" Margin="6,0,0,0"
                        Style="{StaticResource AccentButton}" Click="OnRescan"
                        ToolTip="Пересканировать текущую папку (свёртки и позиция сохранятся)"/>
                <Button DockPanel.Dock="Right" x:Name="ReportButton" Content="Отчёт" Margin="6,0,0,0"
                        Style="{StaticResource ToolButton}" Click="OnReport" ToolTip="Сводка по папкам текущей папки"/>
                <Button DockPanel.Dock="Right" x:Name="FilesButton" Content="Файлы" Margin="6,0,0,0"
                        Style="{StaticResource ToolButton}" Click="OnFileReport" ToolTip="Отчёт по файлам: что занимает место"/>
                <Button DockPanel.Dock="Right" x:Name="CleanupButton" Content="Что удалить?" Margin="6,0,0,0"
                        Style="{StaticResource ToolButton}" Click="OnCleanup"
                        ToolTip="Подсказать, что удалить, чтобы освободить место"/>
                <Button DockPanel.Dock="Right" x:Name="ThemeButton" Content="Светлая тема" Margin="6,0,0,0"
                        Style="{StaticResource ToolButton}" Click="OnToggleTheme"/>
                <Button DockPanel.Dock="Right" x:Name="ResetButton" Content="Сбросить свёртки" Margin="6,0,0,0"
                        Style="{StaticResource ToolButton}" Click="OnResetUnwraps" Visibility="Collapsed"/>
                <TextBox x:Name="PathBox" Margin="6,0,0,0" Style="{StaticResource PathBox}"/>
            </DockPanel>
        </Border>

        <!-- хлебные крошки -->
        <Border Grid.Row="1" Background="{DynamicResource BarBg}" Padding="10,5"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="Breadcrumb">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- основная часть -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="8" CornerRadius="8" Background="{DynamicResource PanelBg}" ClipToBounds="True">
                <local:TreemapView x:Name="Treemap"/>
            </Border>

            <Border Grid.Column="1" Margin="0,8,8,8" CornerRadius="8" Background="{DynamicResource PanelBg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="16,16,16,8">
                        <TextBlock x:Name="DetailName" Foreground="{DynamicResource FgStrong}" FontSize="17"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="DetailPath" Foreground="{DynamicResource FgDim}" FontSize="11.5"
                                   Margin="0,2,0,0" TextWrapping="Wrap" MaxHeight="46"/>
                        <TextBlock x:Name="DetailSize" Foreground="{DynamicResource CrumbFg}" FontSize="13.5" Margin="0,8,0,0"/>
                        <TextBlock x:Name="DetailMeta" Foreground="{DynamicResource FgDim}" FontSize="12" Margin="0,3,0,0"/>
                        <Button x:Name="UnwrapButton" Content="Умное добавление к расчётам" HorizontalAlignment="Left"
                                Margin="0,12,0,0" Style="{StaticResource AccentButton}" Click="OnUnwrapClick"
                                Visibility="Collapsed"
                                ToolTip="Развернуть эту папку до значимых подпапок и подмешать их к текущему виду"/>
                        <Button x:Name="CollapseButton" Content="Свернуть обратно" HorizontalAlignment="Left"
                                Margin="0,8,0,0" Style="{StaticResource ToolButton}" Click="OnCollapseClick"
                                Visibility="Collapsed"/>
                        <Button x:Name="OpenButton" Content="Открыть в проводнике" HorizontalAlignment="Left"
                                Margin="0,8,0,0" Style="{StaticResource ToolButton}" Click="OnOpenInExplorer"
                                Visibility="Collapsed"/>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Background="{DynamicResource Border}" Margin="16,8"/>

                    <ListBox Grid.Row="2" x:Name="ChildList" Margin="6,0,6,8" Background="Transparent"
                             BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource RowItem}"
                             SelectionChanged="OnListSelect" MouseDoubleClick="OnListActivate">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="36">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{Binding Glyph}" Fill="{Binding Swatch}"
                                          Width="14" Height="14" Stretch="Uniform"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="9,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Height="4" CornerRadius="2" Background="{DynamicResource Border}"
                                                Margin="0,4,0,0" Width="150" HorizontalAlignment="Left">
                                            <Border Background="{Binding Swatch}" CornerRadius="2"
                                                    Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="{DynamicResource FgDim}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- строка статуса -->
        <Border Grid.Row="3" Background="{DynamicResource BarBg}" Padding="12,7"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right" x:Name="CreditLink" Text="© Chernyshelly"
                           Foreground="{DynamicResource FgDim}" FontSize="12" VerticalAlignment="Center"
                           Cursor="Hand" Margin="14,0,0,0" MouseLeftButtonUp="OnCredit"
                           ToolTip="О программе · github.com/ChernyshellyOfficial"/>
                <ProgressBar DockPanel.Dock="Right" x:Name="Progress" Width="170" Height="8"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource Accent}"
                             BorderThickness="0" IsIndeterminate="False" Visibility="Collapsed" VerticalAlignment="Center"/>
                <TextBlock x:Name="Status" Foreground="{DynamicResource FgDim}" FontSize="12.5"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
