# Единая политика переносов строк: в репозитории — LF, в рабочей копии
# git подставит нужные под платформу. Убирает «мусорные» разницы и варнинги.
* text=auto

# Явно текстовые типы проекта.
*.cs      text
*.xaml    text
*.csproj  text
*.md      text
*.ps1     text
*.json    text

# Батники ДОЛЖНЫ оставаться CRLF, иначе cmd.exe парсит их криво.
*.cmd     text eol=crlf
*.bat     text eol=crlf

# Бинарные ассеты — не трогать.
*.ico     binary
*.png     binary
