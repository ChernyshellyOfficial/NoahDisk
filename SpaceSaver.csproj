<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>SpaceSaver</AssemblyName>
    <RootNamespace>SpaceSaver</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
    <Version>1.0.0</Version>
    <Authors>Chernyshelly</Authors>
    <Company>Chernyshelly</Company>
    <Product>SpaceSaver</Product>
    <Copyright>© Chernyshelly</Copyright>
    <Description>SpaceSaver — анализатор занятого места на диске. github.com/ChernyshellyOfficial</Description>
    <RepositoryUrl>https://github.com/ChernyshellyOfficial</RepositoryUrl>
    <!-- GUI-версия живёт в gui/ как отдельный проект — не тащим её файлы в консольную сборку. -->
    <DefaultItemExcludes>$(DefaultItemExcludes);gui\**;tests\**;dist\**;dist-portable\**</DefaultItemExcludes>
  </PropertyGroup>

</Project>
